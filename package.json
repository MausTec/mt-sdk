{
  "name": "@maustec/mt-sdk",
  "version": "0.1.0",
  "description": "Maus-Tec plugin SDK: validate, simulate, and build plugins for Maus-Tec hardware",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "bin": {
    "mt-sdk": "./dist/bin/mt-sdk.js",
    "mt-sdk-lsp": "./dist/bin/mt-sdk-lsp.js"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "vscode:install": "pushd vscode && npm run vscode:install && popd"
  },
  "keywords": [
    "maustec",
    "plugin",
    "sdk",
    "wasm",
    "iot"
  ],
  "author": "Maus-Tec LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maustec/mt-sdk.git"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@maustec/mt-runtimes": "file:../mt-runtimes",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
