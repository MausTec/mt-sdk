{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [ "ES2020" ],
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "declaration": false,
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [ "src" ],
    "exclude": [ "node_modules", "dist" ]
}
