{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        [ "do", "end" ],
        [ "(", ")" ],
        [ "[", "]" ]
    ],
    "autoClosingPairs": [
        { "open": "\"", "close": "\"", "notIn": [ "string", "comment" ] },
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" }
    ],
    "surroundingPairs": [
        { "open": "\"", "close": "\"" },
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" }
    ],
    "indentationRules": {
        "increaseIndentPattern": "\\bdo\\b\\s*$",
        "decreaseIndentPattern": "^\\s*\\bend\\b"
    },
    "wordPattern": "[@$]?[a-zA-Z_][a-zA-Z0-9_]*"
}
